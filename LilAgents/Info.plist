<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>LSUIElement</key>
    <true/>
    <key>CFBundleDisplayName</key>
    <string>LilJustin</string>
    <key>CFBundleName</key>
    <string>LilJustin</string>

    <!-- Sparkle auto-update — feed URL + Ed25519 public key.

         The feed URL points at GitHub Releases' /latest/download/ pattern,
         which redirects to whichever semver tag is currently 'Latest'.
         Each release attaches an appcast.xml asset (built by CI) that
         references THAT release's signed .dmg, so Sparkle on an older
         install fetches the latest appcast, compares versions, and
         prompts the user to update.

         The Ed25519 public key here pairs with the SPARKLE_ED_PRIVATE_KEY
         GitHub Actions secret used by CI to sign each .dmg. Sparkle
         refuses to install an update without a matching signature. -->
    <key>SUFeedURL</key>
    <string>https://github.com/justinwilliames-sketch/liljustin/releases/latest/download/appcast.xml</string>
    <key>SUPublicEDKey</key>
    <string>bNQR7ti9TfIVO9mwWWH5hge2A8JzV98AczkncKfitQY=</string>
    <key>SUEnableAutomaticChecks</key>
    <true/>
    <key>SUScheduledCheckInterval</key>
    <integer>86400</integer>
</dict>
</plist>
