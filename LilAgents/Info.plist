<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>LSUIElement</key>
    <true/>
    <!-- CFBundleDisplayName is the user-visible app name in Finder, the
         Dock, alert dialogs, and Sparkle's update prompts. Note: when
         GENERATE_INFOPLIST_FILE = YES is set in the Xcode build settings,
         INFOPLIST_KEY_CFBundleDisplayName from project.pbxproj OVERRIDES
         this static value. Both must match to avoid drift. -->
    <key>CFBundleDisplayName</key>
    <string>Orion by Orbit</string>
    <key>CFBundleName</key>
    <string>Orion by Orbit</string>

    <!-- Sparkle compares the running app's CFBundleShortVersionString
         to sparkle:shortVersionString in the appcast. The CI workflow
         injects MARKETING_VERSION (= the v-tag without the 'v') and
         CURRENT_PROJECT_VERSION (= the workflow run number) so the
         build's version reflects what's tagged. Without this, every
         build defaults to 1.0 and Sparkle thinks the user is ahead of
         every release — updates would never prompt. -->
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>

    <!-- Sparkle auto-update — feed URL + Ed25519 public key.

         The feed URL points at GitHub Releases' /latest/download/ pattern,
         which redirects to whichever semver tag is currently 'Latest'.
         Each release attaches an appcast.xml asset (built by CI) that
         references THAT release's signed .dmg, so Sparkle on an older
         install fetches the latest appcast, compares versions, and
         prompts the user to update.

         The Ed25519 public key here pairs with the SPARKLE_ED_PRIVATE_KEY
         GitHub Actions secret used by CI to sign each .dmg. Sparkle
         refuses to install an update without a matching signature. -->
    <key>SUFeedURL</key>
    <string>https://github.com/justinwilliames-sketch/orion-by-orbit/releases/latest/download/appcast.xml</string>
    <key>SUPublicEDKey</key>
    <string>bNQR7ti9TfIVO9mwWWH5hge2A8JzV98AczkncKfitQY=</string>
    <key>SUEnableAutomaticChecks</key>
    <true/>
    <!-- Check every 30 minutes. Default was 86400 (24h), which made
         Sir's "Sparkle always one behind" experience: during active
         iteration he'd accept a v0.1.X prompt by which time v0.1.X+1
         had shipped, and Sparkle wouldn't notice for another 24h
         without an app relaunch. 1800s closes the gap for active
         users without being noisy — most installs upgrade within
         an hour of a tag landing. -->
    <key>SUScheduledCheckInterval</key>
    <integer>1800</integer>

    <!-- TCC usage descriptions.
         Orion spawns Claude Code / Codex CLI as subprocesses to
         answer the user's questions. Those subprocesses may legitimately
         touch protected user folders (Downloads, Documents, Desktop,
         etc.) when the user mentions a file or asks for something to be
         saved/read. macOS attributes those file-access prompts to the
         "responsible app" — i.e. Orion — and requires a usage
         description string for the prompt to display anything beyond a
         bare path.
         Without these strings the prompts look unexplained and alarming
         ("Orion would like to access Downloads"). With them the user
         sees a one-sentence rationale that matches reality.
         Note: an unsigned app's TCC grants are tied to the binary hash,
         so every Sparkle update wipes prior Allows. Signing the app
         would persist the grants across updates. -->
    <key>NSDownloadsFolderUsageDescription</key>
    <string>Orion spawns the Claude Code / Codex CLI to answer your questions. The CLI may need to read or write files in Downloads when you mention them.</string>
    <key>NSDocumentsFolderUsageDescription</key>
    <string>Orion spawns the Claude Code / Codex CLI to answer your questions. The CLI may need to read or write files in Documents when you mention them.</string>
    <key>NSDesktopFolderUsageDescription</key>
    <string>Orion spawns the Claude Code / Codex CLI to answer your questions. The CLI may need to read or write files on the Desktop when you mention them.</string>
    <key>NSRemovableVolumesUsageDescription</key>
    <string>Orion spawns the Claude Code / Codex CLI to answer your questions. The CLI may need to read or write files on external drives when you mention them.</string>
    <key>NSNetworkVolumesUsageDescription</key>
    <string>Orion spawns the Claude Code / Codex CLI to answer your questions. The CLI may need to read or write files on network shares when you mention them.</string>
    <key>NSAppleEventsUsageDescription</key>
    <string>Orion uses Apple Events to launch Terminal for the post-update Gatekeeper helper, and to invoke the Claude Code / Codex CLI on your behalf.</string>

    <!-- Voice dictation via SFSpeechRecognizer. Required by macOS for the
         microphone-input prompt and the speech-recognition-permission prompt.
         Triggered only when the user clicks the dictation mic button in the
         composer; Orion never opens the mic on its own. -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Orion records audio only while you hold the dictation button in the composer, so you can speak your message instead of typing it.</string>
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>Orion uses Apple's on-device speech recognition to transcribe what you say into the chat box. Audio is processed locally on your Mac whenever the OS supports it.</string>
</dict>
</plist>
